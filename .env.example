# ============================================================
# Career Intelligence Studio — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
# SQLite (default for local development):
DATABASE_URL=sqlite:///career_intelligence_studio.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://cis_user:cis_password@localhost:5432/career_intelligence_studio

# --- Vector Database ---
QDRANT_URL=http://localhost:6333

# --- Cache / Message Broker ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- AI Gateway ---
AI_GATEWAY_URL=http://localhost:8001
# Mode: "mock" (no LLM calls) | "direct" (NVIDIA NIM) | "proxy" (custom gateway)
AI_GATEWAY_MODE=mock
# Required for "direct" or "proxy" mode:
NVIDIA_API_KEY=

# --- Security (REQUIRED in production) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Generate a valid Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=

# --- Application Environment ---
# "development" | "production"
ENV=development

# --- Storage ---
STORAGE_TYPE=local
STORAGE_UPLOAD_DIR=data/uploads
STORAGE_RESUME_DIR=data/resumes
STORAGE_COVER_LETTER_DIR=data/cover_letters
STORAGE_ENCRYPTION_ACTIVE=false

# --- Resume Template ---
RESUME_TEMPLATE_PATH=specs/templates/default_resume.docx
